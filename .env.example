# Required for persistent production storage. Local Node deployments use data/vitala.sqlite.
DATABASE_URL=

# Inquiry notification sender and recipient
ADMIN_EMAIL=partners@vitala.global
FROM_EMAIL=partners@vitala.global

# Choose SendGrid or SMTP
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional canonical origin used by page metadata
VITE_SITE_URL=
